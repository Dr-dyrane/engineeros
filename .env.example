# EngineerOS — environment variables for the push notification functions.
# Copy this file to .env for local reference, and set the SAME names in Vercel
# (Project > Settings > Environment Variables). Never commit real values.
# Full walkthrough: docs/PUSH_SETUP.md

# --- Web Push (VAPID) -------------------------------------------------------
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Upstash Redis (stores anonymous push subscriptions) --------------------
# The Vercel Upstash integration usually injects the KV_ names; the functions
# accept either the UPSTASH_ or the KV_ pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Upstash QStash (daily trigger; the function verifies its signature) -----
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Only needed to publish/schedule from the CLI or console, not by the function:
# QSTASH_URL=
# QSTASH_TOKEN=
